{
  "name": "agent-run-audit-skill",
  "version": "0.1.0",
  "description": "Audit agent transcripts into evidence-oriented run reports.",
  "type": "module",
  "bin": {
    "agent-run-audit": "./bin/agent-run-audit.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "README.md",
    "LICENSE",
